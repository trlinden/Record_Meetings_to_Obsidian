#!/bin/bash

RESUME_TIMESTAMP=""
if [ "$1" = "--resume" ]; then
    shift
    RESUME_TIMESTAMP="$1"
    shift
    if [ -z "$RESUME_TIMESTAMP" ]; then
        echo "❌ --resume requires a timestamp (e.g. --resume 20260407_1431)"
        exit 1
    fi
fi

ATTENDEES="$*"
if [ -n "$RESUME_TIMESTAMP" ]; then
    TIMESTAMP="$RESUME_TIMESTAMP"
else
    TIMESTAMP=$(date +%Y%m%d_%H%M)
fi
DATE_TODAY=$(echo "$TIMESTAMP" | sed 's/\([0-9]\{4\}\)\([0-9]\{2\}\)\([0-9]\{2\}\)_.*/\1-\2-\3/')

# Work from the script's own directory so relative audio paths resolve correctly
# regardless of the caller's working directory (e.g. running from ZoomMeetApp/)
cd "$(dirname "$0")" || exit 1

# Read config from config.yaml (same directory as script)
CONFIG_FILE="$(dirname "$0")/config.yaml"
if [ ! -f "$CONFIG_FILE" ]; then
    echo "❌ Config file not found: $CONFIG_FILE"
    exit 1
fi

yaml_val() { grep "^${1}:" "$CONFIG_FILE" | sed "s/^${1}:[[:space:]]*//" | sed "s|^~|$HOME|"; }

USER_NAME=$(yaml_val user_name)
MICROPHONE="${ZOOMMEET_MIC:-$(yaml_val microphone)}"
OUTPUT_DEVICE="${ZOOMMEET_OUTPUT:-BlackHole 2ch}"
TEMPLATE="${ZOOMMEET_TEMPLATE:-$(yaml_val obsidian_template)}"
MEETINGS_DIR=$(yaml_val meetings_dir)

if [ -z "$USER_NAME" ] || [ -z "$MICROPHONE" ] || [ -z "$TEMPLATE" ] || [ -z "$MEETINGS_DIR" ]; then
    echo "❌ config.yaml must define user_name, microphone, obsidian_template, and meetings_dir"
    exit 1
fi

OUT_FILE="${TIMESTAMP}_out.mp3"
IN_FILE="${TIMESTAMP}_in.mp3"
COMBINED_FILE="${TIMESTAMP}.mp3"
WHISPER_URL="${ZOOMMEET_WHISPER_URL:-$(yaml_val whisper_url)}"
WHISPER_URL="${WHISPER_URL:-http://localhost:8765/inference}"
WHISPER_API_KEY="${ZOOMMEET_WHISPER_API_KEY:-$(yaml_val whisper_api_key)}"
WHISPER_AUTH=()
if [ -n "$WHISPER_API_KEY" ]; then
    WHISPER_AUTH=(-H "Authorization: Bearer ${WHISPER_API_KEY}")
fi
SUMMARY_FILE="${MEETINGS_DIR}/${TIMESTAMP}.md"

if [ -n "$RESUME_TIMESTAMP" ]; then
    # Resume mode — verify the input files exist
    if [ ! -f "$OUT_FILE" ] && [ ! -f "$IN_FILE" ]; then
        # Maybe they were already combined — check for combined file
        if [ -f "$COMBINED_FILE" ]; then
            echo "🔄 Resuming from existing combined file: $COMBINED_FILE"
        else
            echo "❌ Cannot resume: neither ${OUT_FILE}/${IN_FILE} nor ${COMBINED_FILE} found"
            exit 1
        fi
    else
        echo "🔄 Resuming from existing files: $OUT_FILE, $IN_FILE"
    fi
    if [ -n "$ATTENDEES" ]; then
        echo "    Attendees: $ATTENDEES"
    fi

    # Combine tracks if not already done
    if [ ! -f "$COMBINED_FILE" ]; then
        echo ""
        echo "⏳ Combining tracks (archive copy)..."
        sox -M "$OUT_FILE" "$IN_FILE" -c 2 "$COMBINED_FILE"
        if [ $? -ne 0 ]; then
            echo "❌ Combining failed — individual files kept: $OUT_FILE, $IN_FILE"
            exit 1
        fi
        echo "✅ Combined audio saved to: $COMBINED_FILE"
    fi
else
    # Normal recording mode
    cleanup() {
        echo ""
        echo "⚠️  Interrupted — stopping recordings..."
        kill $PID_OUT $PID_IN 2>/dev/null
        wait $PID_OUT $PID_IN 2>/dev/null
        echo "    Individual files kept: $OUT_FILE, $IN_FILE"
        exit 1
    }
    trap cleanup INT TERM

    echo "🎙  Recording started — $(date '+%Y-%m-%d %H:%M')"
    echo "    Output (Zoom audio): $OUT_FILE"
    echo "    Input  (Microphone): $IN_FILE"
    if [ -n "$ATTENDEES" ]; then
        echo "    Attendees: $ATTENDEES"
    fi
    echo ""
    echo "Press Enter to stop recording..."

    # Start both recordings in background (suppress sox progress output)
    sox -t coreaudio -r 48000 "$OUTPUT_DEVICE" -c 2 -C 128 "$OUT_FILE" 2>/dev/null &
    PID_OUT=$!
    sox -t coreaudio -r 48000 "$MICROPHONE" -c 2 -C 128 "$IN_FILE" 2>/dev/null &
    PID_IN=$!

    # Wait for Enter key
    read -r

    # Stop both recordings
    kill $PID_OUT $PID_IN
    wait $PID_OUT $PID_IN 2>/dev/null

    # Disable the trap now that recordings are cleanly stopped
    trap - INT TERM

    echo ""
    echo "⏳ Combining tracks (archive copy)..."
    sox -M "$OUT_FILE" "$IN_FILE" -c 2 "$COMBINED_FILE"

    if [ $? -ne 0 ]; then
        echo "❌ Combining failed — individual files kept: $OUT_FILE, $IN_FILE"
        exit 1
    fi

    echo "✅ Combined audio saved to: $COMBINED_FILE"
fi

# Skip transcription if a transcript already exists (common resume case:
# recording + transcription succeeded but LLM summarization failed)
if [ -n "$RESUME_TIMESTAMP" ] && [ -f "${TIMESTAMP}.txt" ]; then
    echo "✅ Using existing transcript: ${TIMESTAMP}.txt"
else
    # Check whisper server is running
    if ! curl -s "${WHISPER_AUTH[@]}" "$WHISPER_URL" > /dev/null 2>&1; then
        echo "⚠️  Whisper server not reachable at $WHISPER_URL"
        echo "    Check it is running: launchctl list | grep whisper"
        echo "    Logs: cat /tmp/whisper-server.log"
        exit 1
    fi

    # Verify individual track files exist (needed for speaker diarization)
    if [ ! -f "$IN_FILE" ] || [ ! -f "$OUT_FILE" ]; then
        echo "❌ Cannot transcribe: individual track files missing (${IN_FILE}, ${OUT_FILE})"
        echo "    The combined file alone cannot be used for speaker separation."
        exit 1
    fi

    # Transcribe both tracks separately with timestamps for speaker diarization
    echo ""
    echo "⏳ Transcribing microphone (${USER_NAME}) with Whisper..."
    TIM_JSON=$(curl -s "${WHISPER_AUTH[@]}" "$WHISPER_URL" \
        -F file="@${IN_FILE}" \
        -F response_format=verbose_json)

    echo "⏳ Transcribing Zoom audio (Others) with Whisper..."
    OTHERS_JSON=$(curl -s "${WHISPER_AUTH[@]}" "$WHISPER_URL" \
        -F file="@${OUT_FILE}" \
        -F response_format=verbose_json)

    # Validate both transcriptions returned segments
    TIM_COUNT=$(echo "$TIM_JSON" | jq '.segments | length' 2>/dev/null)
    OTHERS_COUNT=$(echo "$OTHERS_JSON" | jq '.segments | length' 2>/dev/null)

    if [ -z "$TIM_COUNT" ] && [ -z "$OTHERS_COUNT" ]; then
        echo "❌ Both transcriptions failed — audio files kept"
        exit 1
    fi

    # Extract segments from each track, tag with speaker, merge, sort by start time
    # Each segment becomes: start_time \t speaker \t text
    TRANSCRIPT=$(
    {
        if [ -n "$TIM_COUNT" ] && [ "$TIM_COUNT" -gt 0 ] 2>/dev/null; then
            echo "$TIM_JSON" | jq -r '.segments[] | "\(.start)\t'"${USER_NAME}"'\t\(.text)"'
        fi
        if [ -n "$OTHERS_COUNT" ] && [ "$OTHERS_COUNT" -gt 0 ] 2>/dev/null; then
            echo "$OTHERS_JSON" | jq -r '.segments[] | "\(.start)\tOthers\t\(.text)"'
        fi
    } | sort -t$'\t' -k1 -g | awk -F'\t' '
        {
            speaker = $2
            text = $3
            # Strip leading/trailing whitespace from text
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", text)
            if (speaker != prev_speaker) {
                if (NR > 1) print ""
                printf "%s: %s", speaker, text
            } else {
                printf " %s", text
            }
            prev_speaker = speaker
        }
        END { print "" }
    ')

    if [ -n "$TRANSCRIPT" ]; then
        {
            if [ -n "$ATTENDEES" ]; then
                echo "Attendees: $ATTENDEES"
                echo ""
            fi
            echo "$TRANSCRIPT"
        } > "${TIMESTAMP}.txt"
        echo "✅ Transcript saved to: ${TIMESTAMP}.txt"
    else
        echo "❌ Transcription produced no output — audio files kept"
        exit 1
    fi

    # Clean up individual track files now that transcription is done
    rm -f "$OUT_FILE" "$IN_FILE"
fi

# --- Summarize and create Obsidian meeting note ---

echo ""
echo "⏳ Preparing Obsidian meeting note..."

# Check template exists
if [ ! -f "$TEMPLATE" ]; then
    echo "❌ Template not found: $TEMPLATE"
    exit 1
fi

# Ensure meetings directory exists
mkdir -p "$MEETINGS_DIR"

# Never overwrite an existing file
if [ -f "$SUMMARY_FILE" ]; then
    echo "❌ Meeting note already exists: $SUMMARY_FILE"
    echo "    Skipping summary to avoid overwriting."
    exit 1
fi

# Copy template and replace the Templater date expression with the actual date
sed "s/<% tp.date.now(\"YYYY-MM-DD\") %>/${DATE_TODAY}/" "$TEMPLATE" > "$SUMMARY_FILE"

# Insert attendee names after # People, one per line, linking known names via people.txt
PEOPLE_FILE="$(dirname "$0")/people.txt"
if [ -n "$ATTENDEES" ]; then
    PEOPLE_LINES=""
    for NAME in $ATTENDEES; do
        LINKED=""
        if [ -f "$PEOPLE_FILE" ]; then
            LINKED=$(grep -i "^${NAME} " "$PEOPLE_FILE" | head -1 | sed -n 's/.*\[\[\(.*\)\]\].*/\[\[\1\]\]/p')
        fi
        if [ -n "$LINKED" ]; then
            PEOPLE_LINES="${PEOPLE_LINES}- ${LINKED}"$'\n'
        else
            PEOPLE_LINES="${PEOPLE_LINES}- ${NAME}"$'\n'
        fi
    done
    # Write to temp file and insert after # People
    printf '%s' "$PEOPLE_LINES" > "${TIMESTAMP}_people_tmp.txt"
    sed -i '' '/^# People$/r '"${TIMESTAMP}_people_tmp.txt" "$SUMMARY_FILE"
    rm -f "${TIMESTAMP}_people_tmp.txt"
fi

echo "⏳ Summarizing with Claude (this may take a while)..."

# Read LLM instructions from external file, substitute {{USER_NAME}}
LLM_INSTRUCTIONS_FILE="$(dirname "$0")/llm_instructions.md"
if [ ! -f "$LLM_INSTRUCTIONS_FILE" ]; then
    echo "❌ LLM instructions file not found: $LLM_INSTRUCTIONS_FILE"
    exit 1
fi
LLM_PROMPT=$(sed "s/{{USER_NAME}}/${USER_NAME}/g" "$LLM_INSTRUCTIONS_FILE")

LLM_COMMAND=$(yaml_val llm_command)
LLM_COMMAND="${LLM_COMMAND:-claude -p --model sonnet}"
LLM_BASE_URL=$(yaml_val llm_base_url)

if [ -n "$LLM_BASE_URL" ]; then
    export OPENAI_API_BASE="$LLM_BASE_URL"
fi

LLM_OUTPUT=$(cat "${TIMESTAMP}.txt" | $LLM_COMMAND "$LLM_PROMPT")

# Extract the Log content (between LOG_START and LOG_END)
LOG_CONTENT=$(echo "$LLM_OUTPUT" | sed -n '/^LOG_START$/,/^LOG_END$/{ /^LOG_START$/d; /^LOG_END$/d; p; }')

# Extract the Action Items content (between ACTIONS_START and ACTIONS_END)
ACTIONS_CONTENT=$(echo "$LLM_OUTPUT" | sed -n '/^ACTIONS_START$/,/^ACTIONS_END$/{ /^ACTIONS_START$/d; /^ACTIONS_END$/d; p; }')

if [ -z "$LOG_CONTENT" ] || [ -z "$ACTIONS_CONTENT" ]; then
    echo "⚠️  LLM output could not be parsed. Raw output saved for review."
    echo "$LLM_OUTPUT" > "${TIMESTAMP}_llm_raw.txt"
    echo "    See: ${TIMESTAMP}_llm_raw.txt"
    echo "    Meeting note created but Log and Action Items are empty: $SUMMARY_FILE"
    exit 1
fi

# Write content to temp files (avoids awk's newline-in-string limitation)
echo "$LOG_CONTENT" > "${TIMESTAMP}_log_tmp.txt"
echo "$ACTIONS_CONTENT" > "${TIMESTAMP}_actions_tmp.txt"

# Insert Log content after "# Log" using sed's r command (reads file after matched line)
sed -i '' '/^# Log$/r '"${TIMESTAMP}_log_tmp.txt" "$SUMMARY_FILE"

# Insert Action Items content after "# Action Items"
sed -i '' '/^# Action Items$/r '"${TIMESTAMP}_actions_tmp.txt" "$SUMMARY_FILE"

# Clean up temp files
rm -f "${TIMESTAMP}_log_tmp.txt" "${TIMESTAMP}_actions_tmp.txt"

echo "✅ Meeting note saved to: $SUMMARY_FILE"
